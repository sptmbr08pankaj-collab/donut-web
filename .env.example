# ---- Copy to your host's Environment Variables (do NOT commit real values) ----

# Public base URL of the deployed site (no trailing slash)
BASE_URL=https://donut.yourcompany.com
PORT=8080

# Random long string for signing sessions (generate your own)
SESSION_SECRET=change-me-to-a-long-random-string

# The single shared password your whole team uses to sign in.
# Pick something strong and share it with the team. (Do NOT use your Google/Zoho admin password.)
APP_PASSWORD=choose-a-strong-shared-password

# Domain used only to label the shared identity (team@<this>) — cosmetic
ALLOWED_DOMAIN=digistay.ai

# ---- Zoho Books (shared, used for ALL users) ----
# Create a "Self Client" in https://api-console.zoho.in  (scope: ZohoBooks.fullaccess.all)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=60062278723
# Data centre: in (India), com (US), eu, au, jp, ...
ZOHO_DC=in

# ---- HubSpot (shared) ----
# Private App token: HubSpot > Settings > Integrations > Private Apps
# Scopes: crm.objects.contacts read/write, crm.objects.owners read, crm.objects.notes read/write
HUBSPOT_TOKEN=

# ---- Razorpay (shared, optional — for payment status) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
